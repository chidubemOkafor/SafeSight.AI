# Local machine: use Hugging Face router
QWEN_URL=https://router.huggingface.co/v1
QWEN_KEY=your_huggingface_token_here
QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# AMD droplet: point to your deployed OpenAI-compatible Qwen server
# QWEN_URL=http://localhost:8000/v1
# QWEN_KEY=dummy
# QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Backward-compatible aliases still work
HF_TOKEN=your_huggingface_token_here
HF_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
